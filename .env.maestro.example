# MAESTRO Stack — Environment Variables
# Copy this file to .env.maestro and fill in your values:
#   cp .env.maestro.example .env.maestro
#
# Then start the stack:
#   docker compose -f docker-compose.maestro.yml --env-file .env.maestro up --build

# ---------------------------------------------------------------------------
# REQUIRED — must be set before starting agent-worker
# ---------------------------------------------------------------------------

# OpenAI API key for LLM calls (gpt-4o-mini and gpt-4o)
OPENAI_API_KEY=sk-your-openai-api-key-here

# GitHub personal access token with repo + issues + pull_requests scopes
GITHUB_TOKEN=ghp_your-github-token-here

# ---------------------------------------------------------------------------
# OPTIONAL — override defaults
# ---------------------------------------------------------------------------

# GitHub repo the agent works on (owner/repo format)
AGENT_REPO=blecx/AI-Agent-Framework

# Absolute path to the workspace directory on the host
# agent-worker mounts this as /workspace inside the container
WORKSPACE_PATH=.

# MCP server ports (must not conflict with existing services)
MEMORY_MCP_PORT=3030
AGENT_BUS_PORT=3031
APPROVAL_GATE_PORT=8001

# ---------------------------------------------------------------------------
# INTERNAL — set automatically by docker-compose.maestro.yml, no need to change
# ---------------------------------------------------------------------------

# Internal URLs used by containers to talk to each other
# MEMORY_MCP_URL=http://mcp-memory:3030
# AGENT_BUS_URL=http://mcp-agent-bus:3031
# APPROVAL_GATE_URL=http://approval-gate:8001
