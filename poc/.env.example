# Hub service
DATABASE_URL=postgresql://hub:hubpass@db:5432/hubdb
ARTIFACT_DIR=/data/artifacts
REPOS_DIR=/data/repos

# LLM Gateway
# Leave blank to run in stub/offline mode
# Set to your local Ollama or OpenAI-compatible URL
UPSTREAM_LLM_URL=

# Agent
GITHUB_TOKEN=
POLL_INTERVAL=5
LEASE_SECONDS=180

# CLI (set when running agentctl against a remote hub)
HUB_URL=http://localhost:8000
